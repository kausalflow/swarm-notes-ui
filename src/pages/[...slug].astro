---
import { getCollection, render } from 'astro:content';
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const allVaultEntries = await getCollection('vault');
  return allVaultEntries.map(entry => {
    const vaultIndex = entry.filePath?.indexOf('vault/');
    let realSlug = entry.id;
    if (entry.filePath && vaultIndex !== -1) {
      realSlug = entry.filePath.substring(vaultIndex + 6).replace(/\.md$/, '');
    }
    return {
      params: { slug: realSlug },
      props: { entry, realSlug },
    };
  });
}

const { entry, realSlug } = Astro.props;
const { Content } = await render(entry);

// Rebuild path map for accurate frontmatter linking
let allFiles = [];
try {
  allFiles = fs.readdirSync(path.resolve('./../vault'), { recursive: true });
} catch (e) {
  try {
    allFiles = fs.readdirSync(path.resolve('../vault'), { recursive: true });
  } catch(err) {}
}

const slugToPath: Record<string, string> = {};
allFiles.forEach(file => {
  if (typeof file === 'string' && file.endsWith('.md')) {
    const s = path.basename(file, '.md').toLowerCase();
    slugToPath[s] = file.replace(/\\/g, '/').replace(/\.md$/, '');
  }
});

const renderValue = (val: any) => {
  if (typeof val === 'string' && val.match(/^\[\[.*\]\]$/)) {
    const rawLink = val.replace(/[[\]]/g, '').trim();
    const cleanLink = rawLink.toLowerCase().replace(/ /g, '-');
    const mappedLink = slugToPath[cleanLink] || cleanLink;
    return `<a href="/${mappedLink}/" class="text-primary hover:underline">${val}</a>`;
  }
  return String(val);
};

// Derive the section from the slug (first path segment)
const slugParts = realSlug.split('/');
const section = slugParts.length > 1 ? slugParts[0] : null;
const sectionLabel = section
  ? section.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())
  : null;
const catalogHref = section ? `/catalog/${section}/` : '/';

const HIDDEN_KEYS = new Set([
  'title', 'slug',
  // CSL nested objects — already rendered in body
  'author', 'issued',
  // internal bookkeeping
  'processed_at', 'generated_stub', 'type',
]);
const frontmatter = Object.entries(entry.data || {}).filter(([key]) => !HIDDEN_KEYS.has(key));
---

<ArticleLayout title={entry.data?.title || realSlug} description="Vault Entry">
  <div class="mb-6 flex items-center gap-2 text-sm text-muted-foreground">
    <a href="/" class="hover:text-foreground transition-colors">Home</a>
    {section && (
      <>
        <span>/</span>
        <a href={catalogHref} class="hover:text-foreground transition-colors">{sectionLabel}</a>
      </>
    )}
    <span>/</span>
    <span class="text-foreground font-medium truncate max-w-xs">{entry.data?.title || realSlug.split('/').pop()}</span>
  </div>

  <!-- Back button -->
  <div class="mb-8">
    <a href={catalogHref} class="inline-flex items-center text-sm font-medium text-muted-foreground hover:text-primary transition-colors">
      <svg class="mr-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to {sectionLabel || 'Catalog'}
    </a>
  </div>
  
  <Content />

  {frontmatter.length > 0 && (
    <div class="mt-16 rounded-xl border bg-card text-card-foreground shadow-sm overflow-hidden">
      <div class="bg-muted/50 px-6 py-4 border-b">
        <h3 class="text-lg font-semibold tracking-tight">Metadata & Links</h3>
      </div>
      <div class="p-6">
        <dl class="space-y-6">
          {frontmatter.map(([key, val]) => (
            <div>
              <dt class="text-sm font-medium text-muted-foreground uppercase tracking-wider mb-2">{key.replace(/-/g, ' ')}</dt>
              <dd class="text-base text-foreground">
                {Array.isArray(val) ? (
                  <div class="flex flex-wrap gap-2">
                    {val.map(v => (
                       <span class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium bg-secondary text-secondary-foreground" set:html={renderValue(v)} />
                    ))}
                  </div>
                ) : (
                  <span set:html={renderValue(val)} />
                )}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  )}
</ArticleLayout>
