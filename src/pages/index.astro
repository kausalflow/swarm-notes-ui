---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';
import { enrichVaultEntry } from "@/lib/vault-utils";

const allVaultEntries = await getCollection('vault');

// Build a flat search index of all entries with their real slugs
const searchIndex = allVaultEntries
  .map(entry => enrichVaultEntry(entry))
  .sort((a, b) => b.sortTimestamp - a.sortTimestamp);

// Stats
const totalBySection: Record<string, number> = {};
searchIndex.forEach(e => {
  totalBySection[e.section] = (totalBySection[e.section] || 0) + 1;
});

// Top-level sections (not papers — they get their own row)
const catalogSections = ['concepts', 'open-questions', 'discussions'];
const sectionMeta: Record<string, { label: string; desc: string; icon: string }> = {
  concepts: { label: 'Concepts', desc: 'Key ideas and terminology from our research', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' },
  'open-questions': { label: 'Open Questions', desc: 'Unsolved problems and research directions', icon: 'M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  discussions: { label: 'Discussions', desc: 'Daily research notes and synthesis', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
};

import siteConfig from '../content/site-config.json';

const configWithKeywords = siteConfig as { paper_keywords?: string[]; arxiv_keywords?: string[] };
const trackedKeywords: string[] = configWithKeywords.paper_keywords ?? configWithKeywords.arxiv_keywords ?? [];

const jsonIndex = JSON.stringify(searchIndex);
---


  <BaseLayout title={siteConfig.site_name} description={siteConfig.site_description}>

  <!-- Compact hero with search -->
  <section class="relative border-b bg-background py-14 md:py-20 overflow-hidden">
    <!-- Subtle gradient orbs -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-24 left-1/2 h-[400px] w-[600px] -translate-x-1/2 rounded-full bg-primary/5 blur-3xl dark:bg-primary/10"></div>
    </div>

    <div class="container relative max-w-3xl mx-auto px-6 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium mb-6 text-muted-foreground">
        <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
        Generated by AI
      </div>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl mb-4">
        {siteConfig.site_name}
      </h1>
      <!-- Research topic pills -->
      {trackedKeywords.length > 0 && (
        <div class="flex flex-wrap justify-center gap-2 mb-8">
          for keywords: {trackedKeywords.map((kw: string) => (
            <span class="rounded-full border bg-muted/50 px-3 py-1 text-xs font-medium text-muted-foreground">
              {kw}
            </span>
          ))}
        </div>
      )}
      <p class="text-lg text-muted-foreground mb-6 max-w-xl mx-auto">
        {siteConfig.site_description}
      </p>


      <!-- Search bar -->
      <div class="relative max-w-xl mx-auto">
        <div class="pointer-events-none absolute inset-y-0 left-4 flex items-center">
          <svg class="h-4 w-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>
        <input
          id="vault-search"
          type="search"
          placeholder="Search concepts, papers, questions…"
          class="w-full rounded-xl border bg-card pl-11 pr-4 py-3 text-sm shadow-sm outline-none ring-offset-background focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all"
          autocomplete="off"
        />
        <!-- Search results dropdown -->
        <div
          id="search-results"
          class="absolute z-[9999] mt-2 w-full rounded-xl border bg-card shadow-xl hidden text-left max-h-80 overflow-y-auto"
        ></div>
      </div>
    </div>
  </section>

  <!-- Recent Discussions — above papers -->
  <section class="py-12 pb-0">
    <div class="container max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold tracking-tight">Recent Discussions</h2>
        <a href="/catalog/discussions/" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline">View all →</a>
      </div>
      <div class="grid gap-3">
        {searchIndex
          .filter(e => e.section === 'discussions')
          .slice(0, 5)
          .map(e => (
            <a
              href={e.href}
              class="group flex items-start gap-4 rounded-xl border border-emerald-200/60 dark:border-emerald-900/40 bg-emerald-50/50 dark:bg-emerald-950/20 px-5 py-4 shadow-sm hover:border-emerald-400/60 hover:shadow-md transition-all"
            >
              <div class="flex-shrink-0 rounded-md bg-emerald-100 dark:bg-emerald-900/50 p-2 text-emerald-700 dark:text-emerald-400 group-hover:bg-emerald-500 group-hover:text-white transition-colors mt-0.5">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <span class="block text-sm font-semibold leading-snug text-emerald-900 dark:text-emerald-100 group-hover:text-emerald-700 dark:group-hover:text-emerald-300 transition-colors">{e.title}</span>
                {e.date && (
                  <span class="mt-1 flex items-center gap-1 text-xs text-emerald-600/70 dark:text-emerald-400/70">
                    <svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    {e.date}
                  </span>
                )}
              </div>
              <svg class="h-4 w-4 text-emerald-400/60 flex-shrink-0 self-center group-hover:text-emerald-600 group-hover:translate-x-1 transition-all" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Papers list — immediately below discussions -->
  <section class="py-12">
    <div class="container max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold tracking-tight">Recent Papers</h2>
        <a href="/catalog/papers/" class="text-sm text-primary hover:underline">View all →</a>
      </div>
      <div class="grid gap-3">
        {searchIndex
          .filter(e => e.section === 'papers')
          .slice(0, 20)
          .map(e => (
            <a
              href={e.href}
              class="group flex items-start gap-4 rounded-xl border bg-card px-5 py-4 shadow-sm hover:border-primary/50 hover:shadow-md transition-all"
            >
              <div class="flex-shrink-0 rounded-md bg-primary/10 p-2 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors mt-0.5">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <span class="block text-sm font-semibold leading-snug group-hover:text-primary transition-colors">{e.title}</span>
                <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1">
                  {e.authors && (
                    <span class="flex items-center gap-1 text-xs text-muted-foreground">
                      <svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                      {e.authors}
                    </span>
                  )}
                  {e.date && (
                    <span class="flex items-center gap-1 text-xs text-muted-foreground">
                      <svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      {e.date}
                    </span>
                  )}
                  {e.domain && (
                    <span class="rounded-full bg-primary/8 px-2 py-0.5 text-xs font-medium text-primary capitalize">{e.domain.replace(/-/g, ' ')}</span>
                  )}
                  {e.arxiv_id && (
                    <span class="text-xs font-mono text-muted-foreground/70">{e.arxiv_id}</span>
                  )}
                </div>
                {e.tags.length > 0 && (
                  <div class="mt-1.5 flex flex-wrap gap-1">
                    {e.tags.map((tag: string) => (
                      <span class="rounded-full border border-border/60 px-2 py-0.5 text-xs text-muted-foreground">{tag.replace(/-/g, ' ')}</span>
                    ))}
                  </div>
                )}
              </div>
              <svg class="h-4 w-4 text-muted-foreground/40 flex-shrink-0 self-center group-hover:text-primary group-hover:translate-x-1 transition-all" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Open Questions list -->
  <section class="py-12 pb-0 section-muted">
    <div class="container max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold tracking-tight">Recent Open Questions</h2>
        <a href="/catalog/open-questions/" class="text-sm text-primary hover:underline">View all →</a>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {searchIndex
          .filter(e => e.section === 'open-questions')
          .slice(0, 8)
          .map(e => (
            <a
              href={e.href}
              class="group flex items-start gap-3 rounded-xl border bg-card px-4 py-3.5 shadow-sm hover:border-primary/50 hover:shadow-md transition-all"
            >
              <div class="flex-shrink-0 rounded-md bg-amber-50 dark:bg-amber-900/30 p-2 text-amber-600 dark:text-amber-400 group-hover:bg-amber-500 group-hover:text-white transition-colors mt-0.5">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <span class="block text-sm font-semibold leading-snug group-hover:text-primary transition-colors">{e.title}</span>
                <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1">
                  {e.date && (
                    <span class="flex items-center gap-1 text-xs text-muted-foreground">
                      <svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      {e.date}
                    </span>
                  )}
                  {e.source_paper_count > 0 && (
                    <span class="flex items-center gap-1 text-xs text-muted-foreground">
                      <svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      {e.source_paper_count} {e.source_paper_count === 1 ? 'source' : 'sources'}
                    </span>
                  )}
                </div>
              </div>
              <svg class="h-4 w-4 text-muted-foreground/40 flex-shrink-0 self-center group-hover:text-primary group-hover:translate-x-1 transition-all" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-y bg-muted/30">
    <div class="container max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 divide-x sm:grid-cols-4">
        {Object.entries(totalBySection).map(([section, count]) => (
          <div class="py-5 px-2 sm:px-4 text-center">
            <div class="text-2xl font-bold">{count}</div>
            <div class="text-xs text-muted-foreground capitalize">{section.replace(/-/g, ' ')}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Catalog section cards (concepts, open-questions, discussions) -->
  <section class="py-16 section-inverted">
    <div class="container max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold tracking-tight mb-8">Browse by Section</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {catalogSections.filter(s => totalBySection[s]).map(s => {
          const meta = sectionMeta[s] || { label: s, desc: '', icon: '' };
          return (
            <a
              href={`/catalog/${s}/`}
              class="group relative flex flex-col gap-4 rounded-xl border bg-card p-6 shadow-sm hover:border-primary/50 hover:shadow-md transition-all"
            >
              <div class="inline-flex w-fit p-2.5 rounded-lg bg-primary/10 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors">
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={meta.icon} />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-lg">{meta.label}</h3>
                <p class="text-sm text-muted-foreground mt-1">{meta.desc}</p>
              </div>
              <div class="mt-auto flex items-center justify-between">
                <span class="text-xs font-medium text-muted-foreground">{totalBySection[s]} items</span>
                <svg class="h-4 w-4 text-muted-foreground group-hover:text-primary group-hover:translate-x-1 transition-all" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Search data embedded safely in DOM -->
<script type="application/json" id="vault-search-data" set:html={jsonIndex}></script>

<script>
  const rawData = document.getElementById('vault-search-data')?.textContent || '[]';
  const entries = JSON.parse(rawData);
  const input = document.getElementById('vault-search');
  const resultsBox = document.getElementById('search-results');

  function renderResults(query) {
    if (!query || query.length < 2) {
      resultsBox.classList.add('hidden');
      resultsBox.innerHTML = '';
      return;
    }
    const q = query.toLowerCase();
    const hits = entries.filter(e =>
      e.title.toLowerCase().includes(q) || e.section.toLowerCase().includes(q)
    ).slice(0, 12);

    if (hits.length === 0) {
      resultsBox.innerHTML = '<div class="px-4 py-6 text-center text-sm text-muted-foreground">No results found.</div>';
      resultsBox.classList.remove('hidden');
      return;
    }

    resultsBox.innerHTML = hits.map(e => `
      <a href="${e.href}" class="flex items-center gap-3 px-4 py-2.5 hover:bg-muted transition-colors">
        <span class="text-xs uppercase tracking-wider text-muted-foreground w-24 flex-shrink-0">${e.section.replace(/-/g, ' ')}</span>
        <span class="text-sm font-medium leading-snug break-words flex-1">${e.title}</span>
      </a>
    `).join('');
    resultsBox.classList.remove('hidden');
  }

  input?.addEventListener('input', e => renderResults(e.target.value));

  document.addEventListener('click', e => {
    if (!input?.contains(e.target) && !resultsBox?.contains(e.target)) {
      resultsBox?.classList.add('hidden');
    }
  });

  // Also handle keyboard: Escape closes results
  input?.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      resultsBox?.classList.add('hidden');
      input.blur();
    }
  });
</script>
