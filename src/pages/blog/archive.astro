---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// Get all blog posts and sort by date (newest first)
const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Format date helper
function formatDate(date: Date) {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title="Blog Archive"
  description="Complete archive of all blog posts"
>
  <div class="container max-w-4xl mx-auto py-16">
    <div class="mb-16">
      <h1 class="text-6xl font-bold tracking-tight mb-6">Archive</h1>
      <p class="text-xl text-muted-foreground">
        Complete list of all blog posts.
      </p>
    </div>

    <ul class="space-y-4">
      {
        sortedPosts.map((post) => (
          <li class="group">
            <a href={`/blog/${post.id}`} class="block p-4 -mx-4 rounded-xl transition-all hover:bg-accent/40 border border-transparent hover:border-border/60">
              <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6">
                <div class="flex items-center gap-2 text-sm text-muted-foreground min-w-[140px]">
                  <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                </div>
                <h2 class="text-lg font-bold group-hover:text-primary transition-colors flex-1">
                  {post.data.title}
                </h2>
                <div class="flex items-center gap-1.5 text-xs text-muted-foreground sm:opacity-0 group-hover:opacity-100 transition-opacity">
                  <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  <span>{post.data.author}</span>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
