---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { enrichVaultEntry } from "@/lib/vault-utils";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const allVaultEntries = await getCollection("vault");

  // Get all unique tags from both blog and vault
  const blogTags = allPosts.map((post) => post.data.tags || []).flat();
  const vaultTags = allVaultEntries.map((entry) => (entry.data as any).tags || []).flat();
  const uniqueTags = [...new Set([...blogTags, ...vaultTags])];

  // Return a path for each tag
  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      (post.data.tags || []).includes(tag)
    );
    const filteredVault = allVaultEntries
      .map(entry => enrichVaultEntry(entry))
      .filter(e => (e.tags || []).includes(tag));

    return {
      params: { tag },
      props: { posts: filteredPosts, vaultEntries: filteredVault },
    };
  });
}

const { tag } = Astro.params;
const { posts, vaultEntries } = Astro.props;

// Sort by date (newest first)
const sortedPosts = posts.sort(
  (a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0)
);
const sortedVault = vaultEntries.sort((a, b) => (b.sortTimestamp || 0) - (a.sortTimestamp || 0));

// Format date helper
function formatDate(date: Date) {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={`Posts tagged "${tag}"`}
  description={`All blog posts tagged with ${tag}`}
>
  <div class="container max-w-4xl mx-auto py-16 px-6">
    <div class="mb-16">
      <a
        href="/tags"
        class="inline-flex items-center text-sm text-muted-foreground hover:text-primary mb-6 transition-colors"
      >
        <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        All tags
      </a>
      <h1 class="text-6xl font-bold tracking-tight mb-6">
        Tagged <span class="text-primary">#{tag}</span>
      </h1>
      <p class="text-xl text-muted-foreground">
        Found {sortedPosts.length + sortedVault.length} items across blog and vault.
      </p>
    </div>

    <div class="space-y-16">
      {sortedPosts.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-8 flex items-center gap-2">
            <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2zM14 2v4h4"/></svg>
            Blog Posts
          </h2>
          <div class="space-y-8">
            {sortedPosts.map((post) => (
              <article class="group">
                <a href={`/blog/${post.id}`} class="block space-y-3 p-6 -mx-6 rounded-2xl transition-all hover:bg-accent/40 border border-transparent hover:border-border/60">
                  <h3 class="text-3xl font-bold tracking-tight group-hover:text-primary transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-lg text-muted-foreground line-clamp-2">
                    {post.data.description}
                  </p>
                  <div class="flex items-center gap-4 text-sm text-muted-foreground">
                    <div class="flex items-center gap-1.5">
                      <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      <time datetime={post.data.pubDate.toISOString()}>
                        {formatDate(post.data.pubDate)}
                      </time>
                    </div>
                    <span>•</span>
                    <div class="flex items-center gap-1.5">
                      <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                      <span>{post.data.author}</span>
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      )}

      {sortedVault.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-8 flex items-center gap-2">
            <svg class="h-6 w-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            Vault Entries
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {sortedVault.map((e) => (
              <a
                href={e.href}
                class="group flex flex-col gap-3 rounded-xl border bg-card p-5 shadow-sm hover:border-primary/50 hover:shadow-md transition-all"
              >
                <div class="flex items-center justify-between">
                  <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground/60">{e.section.replace(/-/g, ' ')}</span>
                  {e.date && <span class="text-[10px] text-muted-foreground">{e.date}</span>}
                </div>
                <h3 class="font-bold leading-tight group-hover:text-primary transition-colors">
                  {e.title}
                </h3>
                {e.authors && (
                  <p class="text-xs text-muted-foreground line-clamp-1 flex items-center gap-1">
                    <svg class="h-3 w-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    {e.authors}
                  </p>
                )}
                {e.tags && e.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-auto pt-1">
                    {e.tags.map((t: string) => (
                      <span class:list={[
                        "px-1.5 py-0.5 rounded text-[10px] border",
                        t === tag ? "bg-primary/10 border-primary/30 text-primary" : "bg-muted/50 border-border/50 text-muted-foreground"
                      ]}>
                        {t}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>
