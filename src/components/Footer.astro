---
import Logo from './Logo.astro';

interface Props {
  variant?: 'boxed' | 'fullWidth';
}

const { variant = 'boxed' } = Astro.props;

const containerClass =
  variant === 'fullWidth' ? 'w-full px-4' : 'container max-w-5xl mx-auto px-4 sm:px-6';
---

<footer class="border-t bg-background">
  <div class:list={[containerClass, 'py-10']}>
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">

      <!-- Brand -->
      <div class="col-span-2 sm:col-span-1">
        <Logo />
        <p class="mt-3 text-sm text-muted-foreground leading-relaxed">
          Automated paper tracking and knowledge synthesis for AI research.
        </p>
      </div>

      <!-- Vault -->
      <div>
        <h3 class="text-sm font-semibold mb-3">Vault</h3>
        <ul class="space-y-2 text-sm text-muted-foreground">
          <li><a href="/catalog/concepts/" class="hover:text-foreground transition-colors">Concepts</a></li>
          <li><a href="/catalog/open-questions/" class="hover:text-foreground transition-colors">Open Questions</a></li>
          <li><a href="/catalog/discussions/" class="hover:text-foreground transition-colors">Discussions</a></li>
          <li><a href="/catalog/papers/" class="hover:text-foreground transition-colors">Papers</a></li>
        </ul>
      </div>

      <!-- Project -->
      <div>
        <h3 class="text-sm font-semibold mb-3">Project</h3>
        <ul class="space-y-2 text-sm text-muted-foreground">
          <li>
            <a href="https://github.com/kausalflow/swarm-notes" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">
              GitHub
            </a>
          </li>
          <li>
            <a href="https://kausalflow.com" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">
              KausalFlow
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="mt-8 border-t pt-6 text-center text-xs text-muted-foreground">
      &copy; {new Date().getFullYear()} KausalFlow. MIT License.
    </div>
  </div>
</footer>
