---
/**
 * Logo Component
 *
 * AstroDeck brand logo with card deck icon and wordmark.
 * Used consistently across Header, Footer, and Auth layouts.
 *
 * @example
 * ```astro
 * <Logo />
 * <Logo showText={false} />
 * <Logo size="lg" />
 * ```
 */
interface Props {
  /** Show the "AstroDeck" text next to the icon */
  showText?: boolean;
  /** Size variant */
  size?: 'sm' | 'md' | 'lg';
  /** Additional CSS classes */
  class?: string;
}

const { showText = true, size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'h-5 w-5',
  md: 'h-6 w-6',
  lg: 'h-8 w-8',
};

const textSizeClasses = {
  sm: 'text-sm',
  md: 'text-base',
  lg: 'text-lg',
};
---

<a href="/" class:list={['flex items-center space-x-2', className]}>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    class={sizeClasses[size]}
    aria-hidden="true"
    fill="none"
  >
    <!-- Notebook body -->
    <rect x="7" y="3" width="18" height="26" rx="2.5" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
    <!-- Binding spine -->
    <line x1="7" y1="9" x2="7" y2="9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
    <circle cx="7" cy="9"  r="1.5" fill="currentColor" opacity="0.7"/>
    <circle cx="7" cy="16" r="1.5" fill="currentColor" opacity="0.7"/>
    <circle cx="7" cy="23" r="1.5" fill="currentColor" opacity="0.7"/>
    <!-- "S" lettermark -->
    <text
      x="16"
      y="21"
      font-family="Georgia, serif"
      font-size="14"
      font-weight="700"
      text-anchor="middle"
      fill="currentColor"
    >S</text>
  </svg>
  {showText && <span class:list={['font-bold', textSizeClasses[size]]}>Swarm Notes</span>}
</a>
